{
  "table_name": "episode_event",
  "description": "Links clinical events to episodes - connects low-level records to episode abstraction",
  "items": [
    {
      "id": "episode_id",
      "name": "Episode ID",
      "description": "Reference to the episode table",
      "data_type": "integer",
      "json_field": "episode_id"
    },
    {
      "id": "event_id",
      "name": "Event ID",
      "description": "Reference to the clinical event (condition, drug, procedure, etc.)",
      "data_type": "integer",
      "json_field": "event_id"
    },
    {
      "id": "event_field_concept_id",
      "name": "Event Field Concept ID",
      "description": "Indicates which table the event_id refers to",
      "data_type": "integer",
      "json_field": "event_field_concept_id"
    }
  ],
  "event_field_concepts": {
    "description": "Concept IDs indicating source table of linked events",
