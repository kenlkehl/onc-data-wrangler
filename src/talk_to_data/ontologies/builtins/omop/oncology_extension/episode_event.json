        "description": "Links to condition_occurrence table"
      },
      {
        "concept_id": 1147094,
        "concept_name": "drug_exposure.drug_exposure_id",
        "description": "Links to drug_exposure table"
      },
      {
        "concept_id": 1147082,
        "concept_name": "procedure_occurrence.procedure_occurrence_id",
        "description": "Links to procedure_occurrence table"
      },
      {
        "concept_id": 1147138,
        "concept_name": "measurement.measurement_id",
        "description": "Links to measurement table"
      },
      {
        "concept_id": 1147165,
        "concept_name": "observation.observation_id",
        "description": "Links to observation table"
      }
    ]
  },
  "usage_patterns": {
    "disease_episode_linkage": {
      "description": "Connect disease episodes to diagnostic events",
      "example": {
        "episode_type": "Disease First Occurrence",
        "linked_events": [
          "condition_occurrence (cancer diagnosis)",
          "procedure_occurrence (diagnostic biopsy)",
          "measurement (staging workup)"
        ]
      }
    },
    "treatment_episode_linkage": {
      "description": "Connect treatment episodes to therapy events",
      "example": {
        "episode_type": "Treatment Regimen",
        "linked_events": [
          "drug_exposure (chemotherapy agents)",
          "procedure_occurrence (radiation therapy)",
          "measurement (response assessment)"
        ]
      }
    }
  }
