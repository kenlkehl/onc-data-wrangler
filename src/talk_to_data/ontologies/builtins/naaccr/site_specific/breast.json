      "json_field": "naaccr_3884_sln_positive",
      "human_readable_field": "sentinel_nodes_positive",
      "description": "Number of positive sentinel lymph nodes",
      "valid_codes": "00=None positive, 01-89=Number positive, 90=90+, 95=Positive aspiration, 97=Positive NOS, 98=Not examined, 99=Unknown",
      "extraction_hints": ["positive sentinel", "SLN positive"]
    },
    {
      "naaccr_item": "3820",
      "name": "LVI (Lymphovascular Invasion)",
      "json_field": "naaccr_3820_lvi",
      "human_readable_field": "lymphovascular_invasion",
