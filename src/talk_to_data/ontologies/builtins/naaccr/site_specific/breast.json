    {
      "naaccr_item": "3935",
      "name": "Tumor Size Summary",
      "json_field": "naaccr_3935_tumor_size",
      "human_readable_field": "tumor_size_mm",
      "description": "Size of primary tumor in millimeters",
      "valid_codes": "Numeric in mm (001-989), 990=990+ mm, 998=Not applicable, 999=Unknown",
      "extraction_hints": ["tumor size", "mass measuring", "cm", "mm", "greatest dimension"]
    },
    {
      "naaccr_item": "3882",
      "name": "LN Positive Axillary Level I-II",
      "json_field": "naaccr_3882_ln_positive_axillary",
      "human_readable_field": "axillary_nodes_positive",
      "description": "Number of positive axillary lymph nodes (levels I-II)",
