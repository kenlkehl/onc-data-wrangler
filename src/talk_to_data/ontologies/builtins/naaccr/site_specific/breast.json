{
  "schema_id": "breast",
  "schema_name": "Breast Cancer",
  "applicable_years": "2018+",
  "primary_site_codes": ["C500", "C501", "C502", "C503", "C504", "C505", "C506", "C508", "C509"],
  "description": "Site-specific data items for breast cancer, AJCC 8th Edition. Includes hormone receptors, HER2 status, and genomic testing.",
  "items": [
    {
      "naaccr_item": "3827",
      "name": "Estrogen Receptor (ER) Summary",
      "json_field": "naaccr_3827_er_summary",
      "human_readable_field": "er_status",
      "description": "Summary of estrogen receptor assay results",
      "valid_codes": "0=ER Negative (<1%), 1=ER Positive, 7=Test ordered, results not in chart, 9=Unknown or not stated, ER not assessed",
      "extraction_hints": ["estrogen receptor", "ER positive", "ER negative", "ER+", "ER-", "ER status"],
      "clinical_significance": "ER+ predicts response to endocrine therapy (tamoxifen, aromatase inhibitors)",
      "required_for_staging": true
    },
    {
      "naaccr_item": "3828",
      "name": "ER Percent Positive or Range",
      "json_field": "naaccr_3828_er_percent",
      "human_readable_field": "er_percent_positive",
      "description": "Percentage of cells staining positive for ER",
      "valid_codes": "000=Negative, 001-100=Percentage, R10=1-10%, R20=11-20%, etc., XX8=Not applicable, XX9=Unknown",
      "extraction_hints": ["ER percentage", "ER %", "percent positive", "Allred"]
    },
    {
      "naaccr_item": "3915",
      "name": "Progesterone Receptor (PR) Summary",
      "json_field": "naaccr_3915_pr_summary",
      "human_readable_field": "pr_status",
      "description": "Summary of progesterone receptor assay results",
      "valid_codes": "0=PR Negative (<1%), 1=PR Positive, 7=Test ordered, 9=Unknown",
      "extraction_hints": ["progesterone receptor", "PR positive", "PR negative", "PR+", "PR-", "PR status"],
      "clinical_significance": "PR+ favorable prognostic factor",
      "required_for_staging": true
    },
    {
      "naaccr_item": "3916",
      "name": "PR Percent Positive or Range",
      "json_field": "naaccr_3916_pr_percent",
      "human_readable_field": "pr_percent_positive",
      "description": "Percentage of cells staining positive for PR",
      "valid_codes": "000=Negative, 001-100=Percentage, XX8=Not applicable, XX9=Unknown",
      "extraction_hints": ["PR percentage", "PR %"]
    },
    {
      "naaccr_item": "3850",
      "name": "HER2 IHC Summary",
      "json_field": "naaccr_3850_her2_ihc_summary",
      "human_readable_field": "her2_ihc_status",
      "description": "HER2 immunohistochemistry test result",
      "valid_codes": "0=Negative (0, 1+), 1=Equivocal (2+), 2=Positive (3+), 7=Test ordered, 8=Not applicable, 9=Unknown",
      "extraction_hints": ["HER2 IHC", "HER2 0", "HER2 1+", "HER2 2+", "HER2 3+", "HER2 by immunohistochemistry"]
    },
    {
      "naaccr_item": "3851",
      "name": "HER2 ISH Summary",
      "json_field": "naaccr_3851_her2_ish_summary",
      "human_readable_field": "her2_ish_status",
      "description": "HER2 in situ hybridization test result (FISH/CISH/SISH)",
      "valid_codes": "0=Negative (not amplified), 1=Positive (amplified), 7=Test ordered, 8=Not applicable, 9=Unknown",
      "extraction_hints": ["HER2 FISH", "HER2 ISH", "HER2 amplified", "HER2 not amplified", "FISH positive", "FISH negative"]
    },
    {
      "naaccr_item": "3855",
      "name": "HER2 Overall Summary",
      "json_field": "naaccr_3855_her2_summary",
      "human_readable_field": "her2_status",
      "description": "Overall HER2 status combining IHC and ISH results",
      "valid_codes": "0=Negative, 1=Positive, 2=Equivocal, 7=Test ordered, 8=Not applicable, 9=Unknown",
      "extraction_hints": ["HER2 positive", "HER2 negative", "HER2+", "HER2-", "HER2 status"],
      "clinical_significance": "HER2+ predicts response to trastuzumab, pertuzumab, T-DM1, T-DXd",
      "required_for_staging": true
    },
    {
      "naaccr_item": "3906",
      "name": "Oncotype DX Recurrence Score - Invasive",
      "json_field": "naaccr_3906_oncotype_dx_score",
      "human_readable_field": "oncotype_dx_score",
      "description": "Oncotype DX recurrence score for invasive breast cancer (0-100)",
      "valid_codes": "000-100=Recurrence score value, XX6=Test performed, score not reported, XX7=Test ordered, XX8=Not applicable, XX9=Unknown",
      "extraction_hints": ["Oncotype DX", "Oncotype", "recurrence score", "RS", "21-gene"],
      "clinical_significance": "Score <26 generally favors omission of adjuvant chemotherapy in node-negative ER+ disease",
      "required_for_staging": true
    },
    {
      "naaccr_item": "3908",
      "name": "Oncotype DX Risk Level - Invasive",
      "json_field": "naaccr_3908_oncotype_dx_risk",
      "human_readable_field": "oncotype_dx_risk_level",
      "description": "Oncotype DX risk level categorization",
      "valid_codes": "0=Low risk (RS <11 or <26 based on clinical trial), 1=Intermediate risk, 2=High risk (RS >=26), 6=Score stated as <11 or >=11, 7=Test ordered, 8=Not applicable, 9=Unknown",
      "extraction_hints": ["low risk", "intermediate risk", "high risk", "Oncotype risk"]
    },
    {
      "naaccr_item": "3907",
      "name": "Oncotype DX Recurrence Score - DCIS",
      "json_field": "naaccr_3907_oncotype_dx_dcis",
      "human_readable_field": "oncotype_dx_dcis_score",
      "description": "Oncotype DX DCIS score for ductal carcinoma in situ",
      "valid_codes": "000-100=Score, XX7=Test ordered, XX8=Not applicable, XX9=Unknown",
      "extraction_hints": ["DCIS score", "Oncotype DCIS"]
    },
    {
      "naaccr_item": "3903",
      "name": "Multigene Signature Method",
      "json_field": "naaccr_3903_multigene_method",
      "human_readable_field": "multigene_assay_type",
      "description": "Type of multigene signature test performed",
      "valid_codes": "1=Oncotype DX, 2=MammaPrint, 3=PAM50/Prosigna, 4=EndoPredict, 5=Breast Cancer Index, 6=Other, 7=Test ordered, 8=Not applicable, 9=Unknown",
      "extraction_hints": ["Oncotype", "MammaPrint", "Prosigna", "PAM50", "EndoPredict", "Breast Cancer Index"]
    },
    {
      "naaccr_item": "3904",
      "name": "Multigene Signature Results",
      "json_field": "naaccr_3904_multigene_results",
      "human_readable_field": "multigene_result_category",
      "description": "Risk category from multigene signature test",
      "valid_codes": "0=Low risk, 1=Intermediate risk, 2=High risk, 6=Results available category not stated, 7=Test ordered, 8=Not applicable, 9=Unknown",
      "extraction_hints": ["low genomic risk", "high genomic risk", "MammaPrint low", "MammaPrint high"]
    },
    {
      "naaccr_item": "3818",
      "name": "Ki-67",
      "json_field": "naaccr_3818_ki67",
      "human_readable_field": "ki67_percentage",
      "description": "Ki-67 proliferation index percentage",
      "valid_codes": "000-100=Percentage, XX7=Test ordered, XX8=Not applicable, XX9=Unknown",
      "extraction_hints": ["Ki-67", "Ki67", "MIB-1", "proliferation index", "proliferative index"],
      "clinical_significance": "High Ki-67 (>20%) may indicate more aggressive disease"
