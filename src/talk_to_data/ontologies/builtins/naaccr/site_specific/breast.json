      "extraction_hints": ["positive axillary", "axillary nodes positive", "lymph node positive"]
    },
    {
      "naaccr_item": "3883",
      "name": "Sentinel Lymph Nodes Examined",
      "json_field": "naaccr_3883_sln_examined",
      "human_readable_field": "sentinel_nodes_examined",
      "description": "Number of sentinel lymph nodes examined",
