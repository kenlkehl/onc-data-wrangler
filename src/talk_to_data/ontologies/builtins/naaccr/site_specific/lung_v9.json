{
  "schema_id": "lung_v9",
  "schema_name": "Lung Cancer (2025+)",
  "applicable_years": "2025+",
  "primary_site_codes": ["C340", "C341", "C342", "C343", "C348", "C349"],
  "description": "Site-specific data items for lung and bronchus cancers, Version 9 (2025+). Includes PD-L1 as official NAACCR item 1174.",
  "extends": "lung",
  "items": [
    {
      "naaccr_item": "3814",
      "name": "Grade Clinical",
      "json_field": "naaccr_3814_grade_clinical",
      "human_readable_field": "grade_clinical",
      "description": "Clinical grade of tumor before treatment",
      "valid_codes": "1=G1 Well differentiated, 2=G2 Moderately differentiated, 3=G3 Poorly differentiated, 4=G4 Undifferentiated, 9=Grade cannot be assessed (GX)",
      "extraction_hints": ["well differentiated", "moderately differentiated", "poorly differentiated", "undifferentiated"]
    },
    {
      "naaccr_item": "3815",
      "name": "Grade Pathological",
      "json_field": "naaccr_3815_grade_pathological",
      "human_readable_field": "grade_pathological",
      "description": "Pathological grade from resection specimen",
      "valid_codes": "Same as Grade Clinical",
      "extraction_hints": ["surgical pathology", "resection", "final path"]
    },
    {
      "naaccr_item": "3929",
      "name": "Separate Tumor Nodules",
      "json_field": "naaccr_3929_separate_tumor_nodules",
      "human_readable_field": "separate_tumor_nodules",
      "description": "Presence and location of separate tumor nodules",
      "valid_codes": "0=No separate tumor nodules, 1=Same lobe, 2=Different ipsilateral lobe, 3=Both same and different, 4=Contralateral lung, 5=Ipsilateral and contralateral, 8=Not applicable, 9=Unknown",
      "extraction_hints": ["satellite nodule", "separate nodule", "additional nodule"]
    },
    {
      "naaccr_item": "3937",
      "name": "Visceral and Parietal Pleural Invasion",
      "json_field": "naaccr_3937_pleural_invasion",
      "human_readable_field": "pleural_invasion",
      "description": "Pleural invasion status",
      "valid_codes": "0=PL0, 1=PL1, 2=PL2, 3=PL3, 4=Both visceral and parietal, 8=Not applicable, 9=Unknown",
      "extraction_hints": ["pleural invasion", "visceral pleura", "parietal pleura"]
    },
    {
      "naaccr_item": "3938",
      "name": "ALK Rearrangement",
      "json_field": "naaccr_3938_alk_rearrangement",
      "human_readable_field": "alk_status",
      "description": "ALK gene rearrangement status",
      "valid_codes": "0=Negative, 1=Positive, 7=Test ordered, 8=Not applicable, 9=Unknown",
      "extraction_hints": ["ALK", "ALK rearrangement", "ALK fusion", "EML4-ALK"],
      "clinical_significance": "Predicts response to ALK inhibitors"
    },
    {
      "naaccr_item": "3939",
      "name": "EGFR Mutational Analysis",
      "json_field": "naaccr_3939_egfr_mutational_analysis",
      "human_readable_field": "egfr_status",
      "description": "EGFR mutation status",
      "valid_codes": "0=Negative, 1=Exon 19 del, 2=L858R, 3=T790M, 4=Exon 20 ins, 5=Other activating, 6=Uncommon, 7=Ordered, 8=N/A, 9=Unknown",
      "extraction_hints": ["EGFR", "exon 19", "L858R", "T790M", "exon 20"],
      "clinical_significance": "Predicts response to EGFR TKIs"
    },
    {
      "naaccr_item": "1174",
      "name": "PD-L1",
      "json_field": "naaccr_1174_pdl1",
      "human_readable_field": "pdl1_tps",
      "description": "PD-L1 Tumor Proportion Score - OFFICIAL NAACCR item for 2025+ cases",
      "valid_codes": "Numeric 0.0-100.0 (percentage), XX.X=Unable to interpret, 988.0=Not applicable (small cell, neuroendocrine)",
      "extraction_hints": ["PD-L1", "PDL1", "TPS", "tumor proportion score", "22C3", "SP263"],
      "clinical_significance": "High PD-L1 (>=50%) predicts better response to pembrolizumab monotherapy",
      "required": true,
      "effective_date": "2025-01-01"
    },
    {
      "naaccr_item": "3940",
      "name": "KRAS Mutation Status",
      "json_field": "naaccr_3940_kras",
      "human_readable_field": "kras_status",
      "description": "KRAS mutation status",
      "valid_codes": "0=Negative, 1=G12C, 2=G12D, 3=G12V, 4=G12A, 5=G13X, 6=Other, 7=Ordered, 9=Unknown",
      "extraction_hints": ["KRAS", "G12C", "G12D", "G12V"],
      "clinical_significance": "KRAS G12C predicts response to sotorasib, adagrasib"
    },
    {
      "naaccr_item": "3941",
      "name": "ROS1 Translocation Status",
      "json_field": "naaccr_3941_ros1",
      "human_readable_field": "ros1_status",
      "description": "ROS1 rearrangement status",
      "valid_codes": "0=Negative, 1=Positive, 7=Ordered, 8=N/A, 9=Unknown",
      "extraction_hints": ["ROS1", "ROS1 rearrangement", "ROS1 fusion"],
      "clinical_significance": "Predicts response to crizotinib, entrectinib"
    },
    {
      "naaccr_item": "3942",
      "name": "BRAF Mutation Status",
      "json_field": "naaccr_3942_braf_lung",
      "human_readable_field": "braf_status",
      "description": "BRAF mutation status",
      "valid_codes": "0=Negative, 1=V600E, 2=Other, 7=Ordered, 9=Unknown",
      "extraction_hints": ["BRAF", "V600E"],
      "clinical_significance": "V600E predicts response to dabrafenib + trametinib"
    },
    {
      "naaccr_item": "3943",
      "name": "MET Status",
      "json_field": "naaccr_3943_met",
      "human_readable_field": "met_status",
      "description": "MET amplification or exon 14 skipping",
      "valid_codes": "0=Negative, 1=Amplification, 2=Exon 14 skip, 3=Both, 7=Ordered, 9=Unknown",
      "extraction_hints": ["MET", "MET amplification", "MET exon 14", "METex14"],
      "clinical_significance": "Predicts response to capmatinib, tepotinib"
    },
    {
      "naaccr_item": "3944",
      "name": "RET Rearrangement Status",
      "json_field": "naaccr_3944_ret",
      "human_readable_field": "ret_status",
      "description": "RET gene rearrangement status",
      "valid_codes": "0=Negative, 1=Positive, 7=Ordered, 9=Unknown",
      "extraction_hints": ["RET", "RET rearrangement", "RET fusion"],
      "clinical_significance": "Predicts response to selpercatinib, pralsetinib"
    },
    {
      "naaccr_item": "3945",
      "name": "NTRK Fusion Status",
      "json_field": "naaccr_3945_ntrk",
      "human_readable_field": "ntrk_status",
      "description": "NTRK gene fusion status",
      "valid_codes": "0=Negative, 1=NTRK1, 2=NTRK2, 3=NTRK3, 4=NOS, 7=Ordered, 9=Unknown",
      "extraction_hints": ["NTRK", "NTRK fusion", "TRK"],
      "clinical_significance": "Predicts response to larotrectinib, entrectinib"
    },
    {
      "naaccr_item": "3946",
      "name": "HER2/ERBB2 Status",
      "json_field": "naaccr_3946_her2_lung",
      "human_readable_field": "her2_status",
      "description": "HER2/ERBB2 mutation or amplification",
      "valid_codes": "0=Negative, 1=Mutation, 2=Amplification, 3=Both, 7=Ordered, 9=Unknown",
      "extraction_hints": ["HER2", "ERBB2"],
      "clinical_significance": "Predicts response to trastuzumab deruxtecan"
    }
