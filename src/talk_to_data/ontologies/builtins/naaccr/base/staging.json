      "json_field": "naaccr_760_tnm_edition",
      "human_readable_field": "ajcc_edition",
      "description": "AJCC TNM edition used for staging",
      "valid_codes": "07=7th edition, 08=8th edition, 09=9th edition, 88=Not applicable, 99=Unknown",
      "data_type": "string",
      "length": 2
    },
    {
      "naaccr_item": "940",
      "name": "TNM Clin T",
      "json_field": "naaccr_940_tnm_clin_t",
      "human_readable_field": "clinical_t",
      "description": "Clinical T category",
      "valid_codes": "cTX, cT0, cTis, cT1, cT1a, cT1b, cT1c, cT2, cT2a, cT2b, cT3, cT4, cT4a, cT4b, etc.",
      "data_type": "string",
      "length": 5
    },
    {
      "naaccr_item": "950",
      "name": "TNM Clin N",
      "json_field": "naaccr_950_tnm_clin_n",
      "human_readable_field": "clinical_n",
      "description": "Clinical N category",
      "valid_codes": "cNX, cN0, cN1, cN1a, cN1b, cN2, cN2a, cN2b, cN3, etc.",
      "data_type": "string",
      "length": 5
    },
    {
      "naaccr_item": "960",
      "name": "TNM Clin M",
      "json_field": "naaccr_960_tnm_clin_m",
      "human_readable_field": "clinical_m",
      "description": "Clinical M category",
      "valid_codes": "cM0, cM1, cM1a, cM1b, cM1c, pM1, etc.",
      "data_type": "string",
      "length": 5
    },
    {
      "naaccr_item": "970",
      "name": "TNM Clin Stage Group",
      "json_field": "naaccr_970_tnm_clin_stage_group",
      "human_readable_field": "clinical_stage_group",
      "description": "Clinical stage group",
      "valid_codes": "0, 0a, 0is, I, IA, IA1, IA2, IA3, IB, IB1, IB2, IC, II, IIA, IIB, IIC, III, IIIA, IIIB, IIIC, IV, IVA, IVB, IVC, OC (occult), etc.",
      "data_type": "string",
      "length": 5
    },
    {
      "naaccr_item": "880",
      "name": "TNM Path T",
      "json_field": "naaccr_880_tnm_path_t",
