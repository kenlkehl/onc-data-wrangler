  "human_readable_mappings": {
    "seer_summary_stage": {
      "0": "In situ",
      "1": "Localized",
      "2": "Regional by direct extension",
      "3": "Regional lymph nodes",
      "4": "Regional by both direct extension and lymph nodes",
      "7": "Distant",
      "8": "Not applicable",
      "9": "Unknown/Unstaged"
    },
    "ajcc_edition": {
      "07": "7th",
      "08": "8th",
      "09": "9th",
      "88": "Not applicable",
      "99": "Unknown"
