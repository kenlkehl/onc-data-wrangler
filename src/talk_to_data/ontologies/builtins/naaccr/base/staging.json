      "length": 3
    },
    {
      "naaccr_item": "3001",
      "name": "EOD Regional Nodes",
      "json_field": "naaccr_3001_eod_regional_nodes",
      "human_readable_field": "eod_regional_nodes",
      "description": "Extent of Disease - Regional Nodes",
      "valid_codes": "Schema-specific codes 000-999",
      "data_type": "string",
      "length": 3
    },
    {
      "naaccr_item": "3002",
      "name": "EOD Mets",
      "json_field": "naaccr_3002_eod_mets",
      "human_readable_field": "eod_mets",
      "description": "Extent of Disease - Distant Metastasis",
      "valid_codes": "00=No distant mets, 10-70=Site-specific distant mets, 99=Unknown",
      "data_type": "string",
      "length": 2
    }
