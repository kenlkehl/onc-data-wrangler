      "data_type": "string",
      "length": 5
    },
    {
      "naaccr_item": "890",
      "name": "TNM Path N",
      "json_field": "naaccr_890_tnm_path_n",
      "human_readable_field": "pathologic_n",
      "description": "Pathologic N category",
      "valid_codes": "pNX, pN0, pN0(i+), pN0(mol+), pN1, pN1a, pN1b, pN1mi, pN2, pN2a, pN2b, pN3, etc.",
      "data_type": "string",
      "length": 5
    },
    {
      "naaccr_item": "900",
      "name": "TNM Path M",
      "json_field": "naaccr_900_tnm_path_m",
      "human_readable_field": "pathologic_m",
      "description": "Pathologic M category",
      "valid_codes": "pM0, pM1, pM1a, pM1b, pM1c (Note: M0 usually clinical only)",
      "data_type": "string",
      "length": 5
    },
    {
      "naaccr_item": "910",
      "name": "TNM Path Stage Group",
      "json_field": "naaccr_910_tnm_path_stage_group",
      "human_readable_field": "pathologic_stage_group",
      "description": "Pathologic stage group",
      "valid_codes": "Same as clinical stage group",
      "data_type": "string",
      "length": 5
    },
    {
      "naaccr_item": "759",
      "name": "SEER Summary Stage 2018",
      "json_field": "naaccr_759_seer_summary_stage_2018",
      "human_readable_field": "seer_summary_stage",
      "description": "SEER Summary Stage 2018",
      "valid_codes": "0=In situ, 1=Localized, 2=Regional by direct extension, 3=Regional lymph nodes, 4=Regional by both, 7=Distant, 8=Not applicable, 9=Unknown",
      "data_type": "string",
      "length": 1
    },
    {
      "naaccr_item": "3000",
      "name": "EOD Primary Tumor",
      "json_field": "naaccr_3000_eod_primary_tumor",
